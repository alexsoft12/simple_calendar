{
    "name": "alexsoft12/simple_calendar",
    "description": "Framework-agnostic calendar generator for PHP",
    "type": "library",
    "keywords": ["calendar", "php", "framework-agnostic", "html", "renderer"],
    "license": "MIT",
    "homepage": "https://github.com/alexsoft12/simple_calendar",
    "authors": [
        {
            "name": "Yuler Figueroa",
            "email": "yuleralex1@gmail.com"            
        }
    ],
    "require": {
        "php": "^8.2"
    },
    "autoload": {
        "psr-4": {
            "Simple\\Calendar\\": "src/Simple/Calendar/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^12.0",
        "squizlabs/php_codesniffer": "4.x-dev"
    },
    "support": {
        "issues": "https://github.com/alexsoft12/simple_calendar/issues",
        "source": "https://github.com/alexsoft12/simple_calendar"
    }
}
